{
  "name": "ses",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:ios": "expo start --ios",
    "start:android": "expo start --android",
    "start:tg": "cross-env EXPO_PUBLIC_TARGET=telegram expo start --web",
    "start:web": "cross-env EXPO_PUBLIC_TARGET=web expo start --web",
    "export:tg": "cross-env EXPO_PUBLIC_TARGET=telegram expo export -p web",
    "export:web": "cross-env EXPO_PUBLIC_TARGET=web expo export -p web",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "build:all": "eas build --platform all --profile production",
    "build:preview": "eas build --platform all --profile preview",
    "build:dev": "eas build --platform all --profile development",
    "build:tg": "cross-env EXPO_PUBLIC_TARGET=telegram vercel --prod",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "reset-project": "node ./scripts/reset-project.js",
    "lint": "expo lint"
  },
  "export": "expo export -p web",
  "dependencies": {
    "@expo/ui": "~56.0.17",
    "@expo/vector-icons": "15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@supabase/supabase-js": "^2.106.0",
    "@tanstack/react-query": "^5.100.14",
    "babel-preset-expo": "~56.0.0",
    "expo": "~56.0.11",
    "expo-auth-session": "~56.0.14",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.18",
    "expo-constants": "~56.0.14",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.17",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.17",
    "expo-notifications": "~56.0.17",
    "expo-observe": "~56.0.20",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "nativewind": "^4.2.4",
    "openai": "^6.42.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.13"
