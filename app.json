{
  "expo": {
    "name": "Ses",
    "slug": "Ses",
    "version": "1.1.2",
    "orientation": "portrait",
    "scheme": "ses",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": {
        "light": "./assets/images/icons/ios-icon-default.png",
        "dark": "./assets/images/icons/ios-icon-dark.png",
        "tinted": "./assets/images/icons/ios-icon-tinted.png"
      },
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/icons/android-icon-foreground.png",
        "monochromeImage": "./assets/images/icons/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "ses",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "package": "com.tclab.Ses",
      "softwareKeyboardLayoutMode": "pan",

      "allowBackup": false,
      "blockedPermissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "android": {
            "image": "./assets/images/icons/splash-android.png",
            "imageWidth": 76,
            "dark": {
              "image": "./assets/images/icons/splash-android.png",
              "imageWidth": 76
            }
          },
          "ios": {
            "image": "./assets/images/icons/splash-ios.png",
            "imageWidth": 120,
            "dark": {
              "image": "./assets/images/icons/splash-ios-dark.png",
              "imageWidth": 120
            }
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-image",
      "expo-status-bar",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "usePrecompiledHeaders": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": false,
            "abiFilters": ["arm64-v8a"],
            "targetSdkVersion": 35,
            "jsEngine": "hermes"
          },
          "ios": {
            "newArchEnabled": true,
            "useFrameworks": "static",
            "jsEngine": "hermes"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icons/android-icon-monochrome.png",
          "color": "#ffffff",
          "iosDisplayInForeground": true,
          "androidMode": "default"
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "39ab4997-67e0-4b5e-bc02-c859e50f203d"
      }
    }
  }
}

