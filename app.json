{
  "expo": {
    "name": "Ses",
    "slug": "Ses",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ses",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": {
        "light": "./assets/images/icons/ios-icon-default.png",
        "dark": "./assets/images/icons/ios-icon-dark.png",
        "tinted": "./assets/images/icons/ios-icon-tinted.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/icons/android-icon-foreground.png",
        "monochromeImage": "./assets/images/icons/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "ses",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "ses",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "package": "com.tclab.Ses"
    },
    "web": {
      "output": "static"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "android": {
            "image": "./assets/images/icons/splash-android.png",
            "imageWidth": 76,
            "dark": {
              "image": "./assets/images/icons/splash-android.png",
              "imageWidth": 76
            }
          },
          "ios": {
            "image": "./assets/images/icons/splash-ios.png",
            "imageWidth": 120,
            "dark": {
              "image": "./assets/images/icons/splash-ios-dark.png",
              "imageWidth": 120
            }
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}

